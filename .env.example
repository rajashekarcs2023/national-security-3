# SpectrumCustody — environment template
#
# Copy to ``.env`` (already gitignored) and fill in your tenant values to
# enable real Palantir Foundry push. With nothing set, the demo runs
# entirely on the local Foundry-shaped sink — every panel still works.
#
# python-dotenv loads this file automatically on backend startup, so
# just edit ``.env`` and run uvicorn — no ``source`` step needed.

# ─────────────────────────────────────────────────────────────────────
# Phase F — real Palantir Foundry remote-tenant transport
# ─────────────────────────────────────────────────────────────────────

# Your Foundry stack URL (no trailing slash). Defaults to the hackathon
# tenant if omitted, so usually you only need to paste FOUNDRY_API below.
FOUNDRY_STACK_URL=https://nshackathon.palantirfoundry.com

# Bearer token for streaming push. Canonical name is FOUNDRY_API
# (FOUNDRY_TOKEN is also accepted as an alias for compatibility).
# From the Foundry UI: Settings → Tokens → "Generate personal access token".
FOUNDRY_API=

# Stream RIDs — one per object type. Get these by creating each stream in
# the Foundry UI (see ``foundry.md`` for the schemas) and copying the
# RID from the stream's "Connect" page.
#
# Two ways to set them — pick whichever you prefer:
#
# 1) JSON-object form (single env var, easy to copy/paste):
#FOUNDRY_STREAM_RIDS={"intelligence_event":"ri.foundry.main.dataset.aaaa-...","attribution":"ri.foundry.main.dataset.bbbb-...","tdoa_fix":"ri.foundry.main.dataset.cccc-...","persistent_emitter":"ri.foundry.main.dataset.dddd-...","blue_force_unit":"ri.foundry.main.dataset.eeee-...","sensor_node":"ri.foundry.main.dataset.ffff-...","emitter_profile":"ri.foundry.main.dataset.gggg-..."}
#
# 2) Per-stream env vars (override individual keys; useful when a stream
# is added later). The names are FOUNDRY_STREAM_RID_<UPPERCASE_KEY>:
#FOUNDRY_STREAM_RID_INTELLIGENCE_EVENT=
#FOUNDRY_STREAM_RID_ATTRIBUTION=
#FOUNDRY_STREAM_RID_TDOA_FIX=
#FOUNDRY_STREAM_RID_PERSISTENT_EMITTER=
#FOUNDRY_STREAM_RID_BLUE_FORCE_UNIT=
#FOUNDRY_STREAM_RID_SENSOR_NODE=
#FOUNDRY_STREAM_RID_EMITTER_PROFILE=

# Tuning (optional — sane defaults).
# DDIL replay buffer directory (one .jsonl file per stream key).
#FOUNDRY_DDIL_BUFFER_DIR=foundry_ddil
# Per-push HTTP timeout in seconds.
#FOUNDRY_REMOTE_TIMEOUT_S=5.0
# Background flush cadence in seconds.
#FOUNDRY_REMOTE_FLUSH_S=2.0

# ─────────────────────────────────────────────────────────────────────
# Phase E — local Foundry-compatible sink
# ─────────────────────────────────────────────────────────────────────

# Local sink output directory (always written to; survives demo without
# any Foundry creds at all).
#FOUNDRY_SINK_DIR=foundry_data

# Push transport for the local sink. ``in_process`` is fastest because the
# sink lives in the same FastAPI process. Set ``http`` only if you've
# moved the sink to a separate node behind ``FOUNDRY_PUSH_URL``.
#FOUNDRY_PUSH_MODE=in_process
#FOUNDRY_PUSH_URL=http://127.0.0.1:8765

# ─────────────────────────────────────────────────────────────────────
# Edge LLM (Ollama)
# ─────────────────────────────────────────────────────────────────────
#OLLAMA_HOST=http://127.0.0.1:11434
#OLLAMA_MODEL=llama3.2:1b
